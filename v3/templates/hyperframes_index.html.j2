<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=1920, height=1080" />
<script src="https://cdn.jsdelivr.net/npm/gsap@3.14.2/dist/gsap.min.js"></script>
<style>
* { margin:0; padding:0; box-sizing:border-box; }
html, body { margin:0; width:1920px; height:1080px; overflow:hidden; background:#0A0C0E; }
body { font-family: "Montserrat", sans-serif; }
.display { font-family: "Oswald", sans-serif; }

/* Scene layering */
.scene {
  position: absolute; top: 0; left: 0;
  width: 1920px; height: 1080px; overflow: hidden;
}
{% for page in pages %}
#scene{{ page.page }} { z-index: {{ page.page }}; background: #0A0C0E; opacity: {% if page.page == 1 %}1{% else %}0{% endif %}; }
{% endfor %}

.scene-content {
  display: flex; flex-direction: column; justify-content: center;
  width: 100%; height: 100%;
  padding: 120px 160px;
  gap: 16px;
  box-sizing: border-box;
  position: relative;
}

/* Ambient decorations */
.bg-glow {
  position: absolute; border-radius: 50%; pointer-events: none;
}
.bg-glow-1 {
  width: 800px; height: 800px;
  background: radial-gradient(circle, rgba(79,195,161,0.08) 0%, transparent 70%);
  top: 50%; left: 50%; transform: translate(-50%, -50%);
}
.bg-glow-2 {
  width: 500px; height: 500px;
  background: radial-gradient(circle, rgba(45,143,207,0.06) 0%, transparent 70%);
  top: 20%; right: 10%;
}

/* Page-level styles injected from components */
{% block extra_styles %}{% endblock %}
</style>
</head>
<body>
<div
  id="root"
  data-composition-id="main"
  data-start="0"
  data-duration="{{ total_duration }}"
  data-width="1920"
  data-height="1080"
>
  <!-- === PERSISTENT DECORATIVES === -->
  <div class="bg-glow bg-glow-1"></div>
  <div class="bg-glow bg-glow-2"></div>

  {% for page in pages %}
  <div id="scene{{ page.page }}" class="scene">
    <div class="scene-content">
      {% block page_{{ page.page }}_content %}{% endblock %}
    </div>
  </div>
  {% endfor %}
</div>

<script>
window.__timelines = window.__timelines || {};
const tl = gsap.timeline({ paused: true });

// Ambient decorations
tl.to(".bg-glow-1", { scale: 1.1, opacity: 0.6, duration: 3, ease: "sine.inOut", yoyo: true, repeat: {{ total_duration // 3 }} }, 0);

{# Animation blocks per page #}
{% block animations %}{% endblock %}

window.__timelines["main"] = tl;
</script>
</body>
</html>
