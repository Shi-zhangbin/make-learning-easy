<!-- ⚠️  DEPRECATED: This file is no longer used by T6. The pipeline now uses v3/steps/t6_compositions.py with the element-driven engine. Kept for reference only. -->
<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=1920,height=1080">
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<style>
{% include "teaching_components.css" %}
</style>
</head>
<body>
<div class="wrap" data-composition-id="{{ sid }}" data-width="1920" data-height="1080">
  <div class="sl">
    <div style="flex:1;display:flex;flex-direction:column;min-height:0;">
    {% block content %}{% endblock %}
    </div>
    <div class="page-number no-animate">{{ page_spec.page_num }}/{{ page_spec.total_pages }}</div>
  </div>
</div>
<script>
(function(){
  var tl = gsap.timeline({paused:true});
  var els = document.querySelector('[data-composition-id="{{ sid }}"] .sl > div:first-child')?.children;
  if(els) {
    var ac = 0;
    for(var i=0; i<els.length; i++) {
      if(els[i].classList.contains('no-animate')) continue;
      tl.from(els[i], {opacity:0, y:12, duration:0.3, ease:"power2.out"}, ac*0.08);
      ac++;
    }
  }
  window.__timelines = window.__timelines || {};
  window.__timelines["{{ sid }}"] = tl;
  window.__hf = window.__hf || {};
  window.__hf["{{ sid }}"] = {duration:{{ page_spec.duration }},seek:function(t){
    var tl=window.__timelines&&window.__timelines["{{ sid }}"];if(tl)tl.seek(t);
  }};
  if(top===self) tl.progress(1);
})();
</script>
</body>
</html>
