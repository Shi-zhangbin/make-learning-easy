{% extends "base.html.j2" %}
{% block content %}
<div class="badge-section no-animate" style="margin-bottom:12px;">{{ page_spec.badge }}</div>
<h1 class="page-title" style="font-size:34px;">{{ page_spec.emoji }} {{ page_spec.title }}</h1>
{% if page_spec.subtitle %}
<p class="page-subtitle" style="font-size:17px;max-width:100%;margin-top:4px;margin-bottom:10px;">{{ page_spec.subtitle }}</p>
{% endif %}
<div style="flex:1;display:flex;flex-direction:column;">
  <div style="display:flex;gap:18px;flex-shrink:0;">
    {% for section in page_spec.sections %}
      {% if section.comparison %}
      <div class="compare-col" style="flex:1;padding:16px;">
        <h4>{{ section.comparison.left_title }}</h4>
        {% for item in section.comparison.left_items %}
        <li>{{ item }}</li>
        {% endfor %}
      </div>
      <div style="width:1px;background:var(--teach-card-border);"></div>
      <div class="compare-col" style="flex:1;padding:16px;">
        <h4 style="color:var(--teach-accent);border-color:var(--teach-accent);">{{ section.comparison.right_title }}</h4>
        {% for item in section.comparison.right_items %}
        <li>{{ item }}</li>
        {% endfor %}
      </div>
      {% endif %}
    {% endfor %}
  </div>
  {% if page_spec.image_slot %}
  <div class="image-rail no-animate" style="flex:1;margin-top:14px;min-height:180px;">
    <img src="{{ page_spec.image_slot }}" style="width:100%;height:100%;object-fit:contain;">
  </div>
  {% endif %}
</div>
{% endblock %}
