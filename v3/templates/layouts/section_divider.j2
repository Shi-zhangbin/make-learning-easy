{% extends "base.html.j2" %}
{% block content %}
<div class="badge-section no-animate" style="margin-bottom:20px;">{{ page_spec.badge }}</div>
<div style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;">
  <h1 class="page-title" class="section-title">{{ page_spec.emoji }} {{ page_spec.title }}</h1>
  {% if page_spec.subtitle %}
  <p class="page-subtitle" style="font-size:20px;max-width:60%;text-align:center;margin-top:4px;">{{ page_spec.subtitle }}</p>
  {% endif %}
</div>
{% if page_spec.image_slot %}
<div class="image-rail no-animate" style="height:200px;margin-top:16px;">
  <img src="{{ page_spec.image_slot }}" style="width:100%;height:100%;object-fit:contain;">
</div>
{% endif %}
{% endblock %}
