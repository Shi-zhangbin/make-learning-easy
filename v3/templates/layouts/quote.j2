{% extends "base.html.j2" %}
{% block content %}
<div class="badge-section no-animate" style="margin-bottom:16px;">{{ page_spec.badge }}</div>
<div style="flex:1;display:flex;gap:18px;align-items:center;">
  <div style="flex:1.2;">
    <h1 class="page-title" style="font-size:36px;">{{ page_spec.emoji }} {{ page_spec.title }}</h1>
    {% if page_spec.subtitle %}
    <p class="page-subtitle" style="font-size:17px;max-width:100%;margin-top:4px;">{{ page_spec.subtitle }}</p>
    {% endif %}
  </div>
  {% if page_spec.image_slot %}
  <div class="image-rail no-animate" style="flex:0.9;height:400px;">
    <img src="{{ page_spec.image_slot }}" style="width:100%;height:100%;object-fit:contain;">
  </div>
  {% endif %}
</div>
{% endblock %}
