{% extends "base.html.j2" %}
{% block content %}
<div style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;">
  <div class="badge-section no-animate" style="margin-bottom:12px;">下期预告</div>
  <h1 class="page-title" style="font-size:42px;">{{ page_spec.emoji }} {{ page_spec.title }}</h1>
  {% if page_spec.subtitle %}
  <p class="page-subtitle" style="font-size:18px;max-width:500px;text-align:center;margin-top:4px;">{{ page_spec.subtitle }}</p>
  {% endif %}
  <div class="cta-button">
    我们下期见 →
  </div>
</div>
{% if page_spec.image_slot %}
<div class="image-rail no-animate" style="height:160px;margin-top:14px;">
  <img src="{{ page_spec.image_slot }}" style="width:100%;height:100%;object-fit:contain;">
</div>
{% endif %}
{% endblock %}
