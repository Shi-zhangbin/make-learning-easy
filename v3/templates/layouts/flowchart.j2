{% extends "base.html.j2" %}
{% block content %}
<div class="badge-section no-animate" style="margin-bottom:12px;">{{ page_spec.badge }}</div>
<h1 class="page-title" style="font-size:34px;">{{ page_spec.emoji }} {{ page_spec.title }}</h1>
{% if page_spec.subtitle %}
<p class="page-subtitle" style="font-size:17px;max-width:100%;margin-top:4px;margin-bottom:10px;">{{ page_spec.subtitle }}</p>
{% endif %}
<div style="flex:1;display:flex;flex-direction:column;">
  <div style="display:flex;align-items:stretch;gap:18px;flex-shrink:0;">
    {% for section in page_spec.sections %}
      {% for card in section.cards %}
      <div class="step-card" style="flex:1;padding:16px;">
        {% if card.icon %}<span class="step-icon" style="font-size:32px;">{{ card.icon }}</span>{% endif %}
        {% if card.title %}<div class="step-title" style="font-size:15px;">{{ card.title }}</div>{% endif %}
        <div class="step-body" style="font-size:14px;">{{ card.body }}</div>
      </div>
      {% if not loop.last %}
      <div class="step-arrow" style="display:flex;align-items:center;">→</div>
      {% endif %}
      {% endfor %}
    {% endfor %}
  </div>
  {% if page_spec.image_slot %}
  <div class="image-rail no-animate" style="flex:1;margin-top:14px;min-height:160px;">
    <img src="{{ page_spec.image_slot }}" style="width:100%;height:100%;object-fit:contain;">
  </div>
  {% endif %}
</div>
{% endblock %}
