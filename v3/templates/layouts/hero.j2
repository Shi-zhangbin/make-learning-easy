{% extends "base.html.j2" %}
{% block content %}
<div class="badge-section no-animate" style="margin-bottom:12px;">{{ page_spec.badge }}</div>
<h1 class="page-title hero-title" style="font-size:56px;">{{ page_spec.emoji }} {{ page_spec.title }}</h1>
{% if page_spec.subtitle %}
<p class="page-subtitle" style="font-size:22px;max-width:80%;margin-top:6px;">{{ page_spec.subtitle }}</p>
{% endif %}

<div style="flex:1;display:flex;flex-direction:column;gap:18px;margin-top:10px;min-height:0;">
  {# Cards zone — natural height #}
  <div style="display:flex;gap:18px;flex-shrink:0;">
  {% for section in page_spec.sections %}
    {% for card in section.cards %}
    <div class="feature-card" style="flex:1;padding:16px 20px;max-width:70%;">
      <p style="font-size:15px;color:var(--teach-body);line-height:1.5;">{{ card.body }}</p>
    </div>
    {% endfor %}
  {% endfor %}
  </div>

  {# Image zone — fills remaining #}
  {% if page_spec.image_slot %}
  <div class="image-rail no-animate" style="flex:1;min-height:200px;">
    <img src="{{ page_spec.image_slot }}" style="width:100%;height:100%;object-fit:contain;">
  </div>
  {% endif %}
</div>
{% endblock %}
