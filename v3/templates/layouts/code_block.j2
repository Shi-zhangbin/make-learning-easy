{% extends "base.html.j2" %}
{% block content %}
<div class="badge-section no-animate" style="margin-bottom:12px;">{{ page_spec.badge }}</div>
<div style="flex:1;display:flex;gap:18px;margin-top:6px;min-height:0;">
  <div class="code-window" style="flex:1.6;display:flex;flex-direction:column;">
    <div class="window-header no-animate" style="flex-shrink:0;">
      <span class="window-dot" style="background:#ff5f56;"></span>
      <span class="window-dot" style="background:#ffbd2e;"></span>
      <span class="window-dot" style="background:#27c93f;"></span>
      <span style="margin-left:10px;font-family:monospace;font-size:12px;color:#888;">python</span>
    </div>
    <div class="window-body" style="flex:1;overflow-y:auto;">{% for section in page_spec.sections %}{% if section.code %}{% for line in section.code.lines %}{{ line }}
{% endfor %}{% endif %}{% endfor %}</div>
  </div>
  <div style="flex:1;display:flex;flex-direction:column;gap:18px;overflow-y:auto;">
    <h1 class="page-title" style="font-size:28px;margin-bottom:0;">{{ page_spec.emoji }} {{ page_spec.title }}</h1>
    {% if page_spec.subtitle %}
    <p class="page-subtitle" style="font-size:16px;max-width:100%;">{{ page_spec.subtitle }}</p>
    {% endif %}
    {% for section in page_spec.sections %}
      {% for card in section.cards %}
      <div class="feature-card" style="padding:14px 18px;">
        <div style="display:flex;gap:10px;align-items:flex-start;">
          {% if card.icon %}<span style="font-size:20px;flex-shrink:0;">{{ card.icon }}</span>{% endif %}
          <div>
            {% if card.title %}<div class="annotation-title">{{ card.title }}</div>{% endif %}
            <p style="font-size:14px;color:var(--teach-body);line-height:1.5;">{{ card.body }}</p>
          </div>
        </div>
      </div>
      {% endfor %}
    {% endfor %}
  </div>
</div>
{% endblock %}
