# Make Learning Easy — API Keys
# ==============================
# Copy this file to .env and fill in your keys.
# All three APIs are optional — the pipeline falls back
# to SVG placeholders if none are configured.
#
# Fallback chain: wuyinkeji → pexels → pixabay → SVG (built-in)
#   - wuyinkeji is the primary LLM image generator (image2 model)
#   - pexels/pixabay are real-photo stock image fallbacks
#   - SVG is the last-resort placeholder (no API key needed)

# ── Primary: wuyinkeji (AI image generation) ──
# Used by T5 to generate illustrations from text prompts.
# Async API: submits a prompt, polls until complete.
# Sign up at https://wuyinkeji.com to get a key.
# This is the "image2" model mentioned in the pipeline docs.
WUYINKEJI_KEY=your_key_here

# ── Fallback 1: Pexels (real stock photos) ──
# Used when wuyinkeji fails or is not configured.
# Searches real photos by keyword.
# Free API key at https://www.pexels.com/api/
PEXELS_API_KEY=your_key_here

# ── Fallback 2: Pixabay (real stock photos) ──
# Used when both wuyinkeji and pexels fail.
# Searches real photos by keyword.
# Free API key at https://pixabay.com/api/docs/
PIXABAY_API_KEY=your_key_here
